	print('swap_hair',value)
	hair_style = hair_style + value
	if hair_style < 0 then
		hair_style = max_hair_style
	elseif hair_style > max_hair_style then
		hair_style = 0
	end
	print('self.hair_style',hair_style)
	gui.set_texture(gui.get_node('character_hair'), hair_cuts[hair_style + 1])
	gui.play_flipbook(gui.get_node('character_hair'), 'idle_' .. rotations[rotation_index] .. '_' .. hair_color)
end

