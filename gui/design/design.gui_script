local auto_layout = require('modules.utility.auto_layout')
local character_info = require('modules.character.character_information')
local navigation = require('modules.utility.navigation')

local selected_input_field_text = ''

local rotations = { "down", "right", "up", "left" }
local rotation_index = 1

local background_index = 1
local max_background_index = 8

local hair_cuts = { "buzzcut", "braids", "curly", "emo", "extralong", "frenchcurl", "gentleman", "midiwave", "spacebuns", "wavy" }
local hair_style = 0
local max_hair_style = 9

local beard_style = 0
local max_beard_style = 0

local shirts = { "basic", "floral", "overall", "sailor", "sailor_bow", "sporty", "suit" }
local shirt_style = 0
local max_shirt_style = 6

local pants = { "pants", "pants_suit", "skirt" }
local pants_style = 0
local max_pants_style = 2

local shoes_color = 0
local max_shoes_color = 9

local skin_color = 0
local max_skin_color = 7

local hair_color = 0
local max_hair_color = 9

local shirt_color = 0
local max_shirt_color = 9

local pants_color = 0
local max_pants_color = 9

local eye_color = 0
local max_eye_color = 9

local function rotate_player(value)
	print('rotate_player',value)
	rotation_index = rotation_index + value
	if rotation_index < 1 then
		rotation_index = #rotations
	elseif rotation_index > #rotations then
		rotation_index = 1
	end
	print('self.rotation_index',rotation_index)
	gui.play_flipbook(gui.get_node('character_body'), 'idle_' .. rotations[rotation_index] .. '_' .. skin_color)
	gui.play_flipbook(gui.get_node('character_hair'), 'idle_' .. rotations[rotation_index] .. '_' .. hair_color)
	gui.play_flipbook(gui.get_node('character_shirt'), 'idle_' .. rotations[rotation_index] .. '_' .. shirt_color)
	gui.play_flipbook(gui.get_node('character_pants'), 'idle_' .. rotations[rotation_index] .. '_' .. pants_color)
	gui.play_flipbook(gui.get_node('character_shoes'), 'idle_' .. rotations[rotation_index] .. '_' .. shoes_color)
	gui.play_flipbook(gui.get_node('character_eyes'), 'idle_' .. rotations[rotation_index] .. '_' .. eye_color)
end

local function swap_background(value)
	print('swap_background',value)
	background_index = background_index + value
	if background_index < 1 then
		background_index = max_background_index
	elseif background_index > max_background_index then
		background_index = 1
	end
	print('self.background_index',background_index)
	gui.play_flipbook(gui.get_node('character_background'), '' .. background_index)
end

local function open_name(self)
	print('open_name')
	msg.post('virtual_keyboard#virtual_keyboard', 'toggle', { url = 'character_design#character_design' })
	selected_input_field = 'name_input_field'
	selected_input_field_text = 'name_input_entry'
end

local function open_farm_name()
	print('open_farm_name')
	msg.post('virtual_keyboard#virtual_keyboard', 'toggle', { url = 'character_design#character_design' })
	selected_input_field = 'farm_name_input_field'
	selected_input_field_text = 'farm_name_input_entry'
end

local function open_fav_thing()
	print('open_fav_thing')
	msg.post('virtual_keyboard#virtual_keyboard', 'toggle', { url = 'character_design#character_design' })
	selected_input_field = 'favorite_thing_input_field'
	selected_input_field_text = 'favorite_thing_input_entry'
end

