local function start()
	print('start')
end

function init(self)
	msg.post(".", "acquire_input_focus")
	print('url design',msg.url())

	gui.play_flipbook(gui.get_node('character_body'), 'idle_' .. rotations[rotation_index] .. '_' .. skin_color)

	gui.set_texture(gui.get_node('character_hair'), hair_cuts[hair_style + 1])
	gui.play_flipbook(gui.get_node('character_hair'), 'idle_' .. rotations[rotation_index] .. '_' .. hair_color)

	gui.set_texture(gui.get_node('character_shirt'), shirts[shirt_style + 1])
	gui.play_flipbook(gui.get_node('character_shirt'), 'idle_' .. rotations[rotation_index] .. '_' .. shirt_color)

	gui.set_texture(gui.get_node('character_pants'), pants[pants_style + 1])
	gui.play_flipbook(gui.get_node('character_pants'), 'idle_' .. rotations[rotation_index] .. '_' .. pants_color)

	gui.play_flipbook(gui.get_node('character_shoes'), 'idle_' .. rotations[rotation_index] .. '_' .. shoes_color)
	gui.play_flipbook(gui.get_node('character_eyes'), 'idle_' .. rotations[rotation_index] .. '_' .. eye_color)

	self.character_design = gui.get_node('root')

	self.navigation_buttons = {}
	--navigation.set_selected('arrow_rotate_left')

	auto_layout.setup_layout('vertical', { 'name_content', 'farm_name_content', 'favorite_thing_content' }, 6.5, '', '')
	auto_layout.setup_layout('vertical', { 'hair_content', 'beard_content', 'shirt_content', 'pants_content', 'shoes_content' }, 0, '', '')
	auto_layout.setup_layout('vertical', { 'skin_content', 'hair_color_content', 'shirt_color_content', 'pants_color_content', 'eyes_content' }, 0, '', '')

	navigation.add_focusable(self, 'arrow_rotate_left', function ()
		rotate_player(-1)
	end)
	navigation.add_focusable(self, 'arrow_rotate_right', function ()
		rotate_player(1)
	end)
	navigation.add_focusable(self, 'arrow_background_left', function ()
		swap_background(-1)
	end)
	navigation.add_focusable(self, 'arrow_background_right', function ()
		swap_background(1)
	end)

	navigation.add_focusable(self, 'name_input_field', open_name)
	navigation.add_focusable(self, 'farm_name_input_field', open_farm_name)
	navigation.add_focusable(self, 'favorite_thing_input_field', open_fav_thing)

	navigation.add_focusable(self, 'hair_left_arrow', function ()
		swap_hair(-1)
	end)
	navigation.add_focusable(self, 'hair_right_arrow', function ()
		swap_hair(-1)
	end)
	navigation.add_focusable(self, 'beard_left_arrow', function ()
		swap_beard(-1)
	end)
	navigation.add_focusable(self, 'beard_right_arrow', function ()
		swap_beard(-1)
	end)
	navigation.add_focusable(self, 'shirt_left_arrow', function ()
		swap_shirt(-1)
	end)
	navigation.add_focusable(self, 'shirt_right_arrow', function ()
		swap_shirt(1)
	end)
	navigation.add_focusable(self, 'pants_left_arrow', function ()
		swap_pants(-1)
	end)
	navigation.add_focusable(self, 'pants_right_arrow', function ()
		swap_pants(1)
	end)
	navigation.add_focusable(self, 'shoes_left_arrow', function ()
		swap_shoes(-1)
	end)
	navigation.add_focusable(self, 'shoes_right_arrow', function ()
		swap_shoes(1)
	end)

	navigation.add_focusable(self, 'skin_left_arrow', function ()
		swap_skin(-1)
	end)
	navigation.add_focusable(self, 'skin_right_arrow', function ()
		swap_skin(1)
	end)
	navigation.add_focusable(self, 'hair_color_left_arrow', function ()
		swap_hair_color(-1)
	end)
	navigation.add_focusable(self, 'hair_color_right_arrow', function ()
		swap_hair_color(1)
	end)
	navigation.add_focusable(self, 'shirt_color_left_arrow', function ()
		swap_shirt_color(-1)
	end)
	navigation.add_focusable(self, 'shirt_color_right_arrow', function ()
		swap_shirt_color(1)
	end)
	navigation.add_focusable(self, 'pants_color_left_arrow', function ()
		swap_pants_color(-1)
	end)
	navigation.add_focusable(self, 'pants_color_right_arrow', function ()
		swap_pants_color(1)
	end)
	navigation.add_focusable(self, 'eye_color_left_arrow', function ()
		swap_eye_color(-1)
	end)
	navigation.add_focusable(self, 'eye_color_right_arrow', function ()
		swap_eye_color(1)
	end)

	navigation.add_focusable(self, 'start_button', start)
end

function final(self)
end

function update(self, dt)
	navigation.update(dt)
end

function on_message(self, message_id, message, sender)
	if message_id == hash('toggle') then
		if not gui.is_enabled(self.character_design, false) then
			gui.set_enabled(self.character_design, true)
			navigation.set_selected('arrow_rotate_left')
			character_info.can_move = false
		else
			gui.set_enabled(self.character_design, false)
		end
	elseif message_id == hash('finished_typing') then
		gui.set_text(gui.get_node(selected_input_field_text), message.message)
		navigation.set_selected(selected_input_field)
		selected_input_field = ''
		selected_input_field_text = ''
	end
end

function on_input(self, action_id, action)
	if not gui.is_enabled(self.character_design, false) then
		return
	end

	navigation.handle_navigation(self, action_id, action)
end